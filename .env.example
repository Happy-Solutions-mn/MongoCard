# Production-ын URL (sitemap, OG image, share text-д ашиглана)
NEXT_PUBLIC_SITE_URL=https://mongocard.mn

# Google AdSense (тохируулаагүй бол placeholder UI харагдана)
# Эх үүсвэр: https://www.google.com/adsense/
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_BANNER_SLOT=1234567890

# Хичнээн карт тутамд interstitial ад харуулах вэ (default: 8)
# NEXT_PUBLIC_AD_FREQUENCY=8

# Ирээдүйн backend (одоогоор ашиглахгүй)
# NEXT_PUBLIC_API_URL=https://api.mongocard.mn
